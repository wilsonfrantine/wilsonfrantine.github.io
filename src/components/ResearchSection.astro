---
import { getCollection } from 'astro:content';
import { Quote, ExternalLink } from 'lucide-astro';
import PublicationCard from './PublicationCard.astro';

interface Props {
  publications: any[];
}

const { publications } = Astro.props;
---

<section id="research" class="py-24 px-6 bg-slate-950 relative overflow-hidden">
    <!-- Efeito de Luz de Fundo -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-sky-500/5 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto relative z-10">
        <div class="mb-16 text-center">
            <h2 class="text-4xl md:text-5xl font-black text-white mb-6 tracking-tight">Impacto Científico</h2>
            <p class="text-slate-400 max-w-2xl mx-auto font-mono text-sm leading-relaxed">
                Produção acadêmica focada em genética de populações, ecologia de peixes e conservação da biodiversidade neotropical.
            </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {publications.slice(0, 6).map((pub) => (
                <PublicationCard 
                    title={pub.title}
                    year={pub.year}
                    journal={pub.journal}
                    url={pub.url}
                />
            ))}
        </div>

        <div class="mt-16 text-center">
            <a href="https://orcid.org/0000-0002-4293-0471" class="text-sky-400 font-mono text-xs uppercase tracking-widest hover:text-white transition-colors flex items-center justify-center gap-2">
                Ver Currículo Lattes / ORCID <ExternalLink size={14} />
            </a>
        </div>
    </div>
</section>
