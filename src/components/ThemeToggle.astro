---
import { Sun, Moon } from 'lucide-astro';
---

<button
  id="theme-toggle"
  class="p-2.5 rounded-full bg-slate-900/50 border border-white/10 text-slate-400 hover:text-sky-400 hover:border-sky-500/30 transition-all backdrop-blur-md"
  aria-label="Alternar tema"
>
  <Sun id="sun-icon" size={18} class="hidden dark:block" />
  <Moon id="moon-icon" size={18} class="block dark:hidden" />
</button>

<script>
  function setupThemeToggle() {
    const themeToggle = document.getElementById("theme-toggle");
    
    if (themeToggle) {
      themeToggle.removeEventListener("click", handleToggle);
      themeToggle.addEventListener("click", handleToggle);
    }
  }

  function handleToggle() {
    const element = document.documentElement;
    element.classList.toggle("dark");
    const isDark = element.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    element.style.colorScheme = isDark ? "dark" : "light";
  }

  setupThemeToggle();
  document.addEventListener('astro:page-load', setupThemeToggle);
</script>
