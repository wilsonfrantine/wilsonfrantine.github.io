---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ActivityLog from '../components/ActivityLog.astro';
import ProjectsSection from '../components/ProjectsSection.astro';
import ResearchSection from '../components/ResearchSection.astro';
import TeachingSection from '../components/TeachingSection.astro';
import ContactSection from '../components/ContactSection.astro';
import { featuredProjects } from '../data/featured';
import { getOrcidPublications } from '../data/orcid-publications';

const projects = featuredProjects;
const publications = await getOrcidPublications();
---

<Layout title="TATAbox | Genética & Bioinformática">
	<main class="relative bg-white dark:bg-slate-950 bg-dot-grid min-h-screen transition-colors duration-300">
		<section id="hero">
			<Hero />
		</section>
		
		<ActivityLog />
		
		<section id="projects">
			<ProjectsSection projects={projects} />
		</section>
		
		<section id="research">
			<ResearchSection publications={publications} />
		</section>
		
		<section id="teaching">
			<TeachingSection />
		</section>
		
		<section id="contact">
			<ContactSection />
		</section>

		<footer class="py-12 border-t border-white/5 text-center">
			<p class="text-slate-600 text-[10px] font-mono uppercase tracking-[0.5em]">
				&copy; {new Date().getFullYear()} Wilson Frantine-Silva. TATAbox v1.0
			</p>
		</footer>
	</main>
</Layout>
