---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const tutorialEntries = await getCollection('tutorials');
  return tutorialEntries.map(entry => ({
    params: { slug: entry.id }, 
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={`${entry.data.title} | TATAbox Tutorials`}>
  <main class="relative bg-slate-950 min-h-screen py-32 px-4 max-w-4xl mx-auto">
    <!-- Navegação de Voltar -->
    <a href="/" class="inline-flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-sky-500 hover:text-white transition-colors mb-12">
      ← Voltar para a Bancada
    </a>

    <article class="prose prose-invert prose-sky max-w-none">
      <header class="mb-16 not-prose">
        <div class="flex items-center gap-3 text-[10px] font-mono uppercase tracking-[0.2em] text-slate-500 mb-4">
          <span class="px-2 py-0.5 border border-slate-800 rounded">{entry.data.category}</span>
          <span>{entry.data.pubDate.toLocaleDateString('pt-BR')}</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-black text-white mb-6 tracking-tight leading-tight">
          {entry.data.title}
        </h1>
        <p class="text-xl text-slate-400 font-light leading-relaxed italic">
          {entry.data.description}
        </p>
      </header>

      <div class="content text-slate-300 leading-relaxed text-lg">
        <Content />
      </div>

      <footer class="mt-20 pt-10 border-t border-slate-900 not-prose">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 bg-sky-500/10 border border-sky-500/20 rounded-full flex items-center justify-center font-mono text-sky-400 font-bold">
            WF
          </div>
          <div>
            <p class="text-xs font-mono uppercase tracking-widest text-slate-500">Escrito por</p>
            <p class="text-sm font-bold text-white">{entry.data.author}</p>
          </div>
        </div>
      </footer>
    </article>
  </main>
</Layout>

<style is:global>
  @reference "../../styles/global.css";
  
  /* Adicionando estilos extras para o Markdown */
  .content h1, .content h2, .content h3 {
    @apply font-black text-white tracking-tight mt-12 mb-6;
  }
  .content h2 { @apply text-3xl; }
  .content h3 { @apply text-2xl; }
  .content p { @apply mb-6; }
  .content ul { @apply list-disc pl-6 mb-6 space-y-2; }
  .content ol { @apply list-decimal pl-6 mb-6 space-y-2; }
  .content blockquote { @apply border-l-4 border-sky-500/40 pl-6 italic text-slate-400 my-10; }
  .content pre { @apply bg-slate-900 border border-slate-800 p-6 rounded-xl my-8 overflow-x-auto; }
  .content code { @apply font-mono text-sky-400 text-sm bg-sky-400/10 px-1.5 py-0.5 rounded; }
  .content pre code { @apply bg-transparent p-0 text-slate-300; }
</style>
