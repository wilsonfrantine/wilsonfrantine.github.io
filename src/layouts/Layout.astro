---
import '../styles/global.css';
import { Menu, X } from 'lucide-astro';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
	title: string;
	description?: string;
	image?: string;
}

const { 
	title, 
	description = "TATAbox | Hub de Recursos Didáticos, Scripts e Ferramentas para Genética e Bioinformática.",
	image = "/og-image.png"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO Primário -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url)} />

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">

		<!-- Inline theme script to prevent FOUC -->
		<script is:inline>
			const getTheme = () => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			};
			const theme = getTheme();
			if (theme === 'dark') {
				document.documentElement.classList.add('dark');
				document.documentElement.style.colorScheme = 'dark';
			} else {
				document.documentElement.classList.remove('dark');
				document.documentElement.style.colorScheme = 'light';
			}
			window.localStorage.setItem('theme', theme);
		</script>
	</head>
	<body class="bg-white dark:bg-slate-950 bg-dot-grid text-slate-600 dark:text-slate-300 font-sans selection:bg-sky-500/30 overflow-x-hidden transition-colors duration-300">
		<!-- Navegação Global -->
		<nav class="fixed top-0 left-0 w-full z-50 px-8 py-6 flex justify-between items-center backdrop-blur-md bg-white/80 dark:bg-slate-950/80 border-b border-slate-200 dark:border-white/5">
			<a href="/" class="font-mono text-xs tracking-[0.3em] text-sky-600 dark:text-sky-500 font-bold uppercase z-50">
				TATA<span class="text-slate-900 dark:text-white">box</span> <span class="text-slate-300 dark:text-slate-800 mx-2">//</span> <span class="text-slate-400 dark:text-slate-500 font-normal">Bio+Info</span>
			</a>

			<div class="flex items-center gap-8">
				<!-- Menu Desktop -->
				<ul class="hidden md:flex gap-10 text-[10px] font-mono tracking-[0.2em] uppercase text-slate-400 dark:text-slate-500">
					<li><a href="/#hero" class="hover:text-slate-900 dark:hover:text-white transition-colors font-bold">Início</a></li>
					<li><a href="/#projects" class="hover:text-slate-900 dark:hover:text-white transition-colors font-bold">Projetos</a></li>
					<li><a href="/#research" class="hover:text-slate-900 dark:hover:text-white transition-colors font-bold">Pesquisa</a></li>
					<li><a href="/#teaching" class="hover:text-slate-900 dark:hover:text-white transition-colors font-bold">Recursos</a></li>
					<li><a href="/#contact" class="hover:text-slate-900 dark:hover:text-white transition-colors font-bold">Networking</a></li>
				</ul>

				<ThemeToggle />

				<!-- Botão Mobile -->
				<button id="menu-toggle" class="md:hidden text-slate-900 dark:text-white z-50 focus:outline-none p-2" aria-label="Abrir menu">
					<Menu id="menu-icon" size={24} />
					<X id="close-icon" size={24} class="hidden" />
				</button>
			</div>

			<!-- Menu Mobile Overlay -->
			<div id="mobile-menu" class="fixed inset-0 bg-white dark:bg-slate-950 flex flex-col items-center justify-center translate-x-full transition-transform duration-300 md:hidden">
				<ul class="flex flex-col gap-10 text-xs font-mono tracking-[0.4em] uppercase text-slate-400 dark:text-slate-500 text-center px-8">
					<li><a href="/#hero" class="mobile-link hover:text-slate-900 dark:hover:text-white transition-colors block py-2 font-bold">Início</a></li>
					<li><a href="/#projects" class="mobile-link hover:text-slate-900 dark:hover:text-white transition-colors block py-2 font-bold">Projetos</a></li>
					<li><a href="/#research" class="mobile-link hover:text-slate-900 dark:hover:text-white transition-colors block py-2 font-bold">Pesquisa</a></li>
					<li><a href="/#teaching" class="mobile-link hover:text-slate-900 dark:hover:text-white transition-colors block py-2 font-bold">Recursos</a></li>
					<li><a href="/#contact" class="mobile-link hover:text-slate-900 dark:hover:text-white transition-colors block py-2 font-bold">Networking</a></li>
				</ul>
				<div class="absolute bottom-12 font-mono text-[8px] text-slate-300 dark:text-slate-800 tracking-[0.5em] uppercase">
					Wilson Frantine-Silva // TATAbox
				</div>
			</div>
		</nav>

		<slot />

		<script>
			function initGlobalScripts() {
				// 1. Menu Mobile
				const menuToggle = document.getElementById('menu-toggle');
				const mobileMenu = document.getElementById('mobile-menu');
				const menuIcon = document.getElementById('menu-icon');
				const closeIcon = document.getElementById('close-icon');
				const mobileLinks = document.querySelectorAll('.mobile-link');

				function toggleMenu() {
					if (mobileMenu && menuIcon && closeIcon) {
						mobileMenu.classList.toggle('translate-x-full');
						menuIcon.classList.toggle('hidden');
						closeIcon.classList.toggle('hidden');
						document.body.style.overflow = mobileMenu.classList.contains('translate-x-full') ? 'auto' : 'hidden';
					}
				}

				menuToggle?.replaceWith(menuToggle.cloneNode(true)); // Limpa listeners antigos
				document.getElementById('menu-toggle')?.addEventListener('click', toggleMenu);

				mobileLinks.forEach(link => {
					link.addEventListener('click', toggleMenu);
				});

				// 2. Automação Inteligente de Links Externos
				const links = document.getElementsByTagName('a');
				const currentHost = window.location.host;

				for (let link of links) {
					const href = link.getAttribute('href');
					if (href && (href.startsWith('http') || href.startsWith('//'))) {
						try {
							const linkUrl = new URL(href, window.location.origin);
							if (linkUrl.host !== currentHost) {
								link.setAttribute('target', '_blank');
								link.setAttribute('rel', 'noopener noreferrer');
							}
						} catch (e) {
							link.setAttribute('target', '_blank');
							link.setAttribute('rel', 'noopener noreferrer');
						}
					}
				}

				// 3. Botões de Cópia em Blocos de Código
				document.querySelectorAll('pre').forEach((block) => {
					if (navigator.clipboard && !block.querySelector('.copy-button')) {
						const button = document.createElement('button');
						button.innerText = 'Copy';
						button.className = 'copy-button';
						block.appendChild(button);

						button.addEventListener('click', async () => {
							const text = block.querySelector('code')?.innerText || '';
							await navigator.clipboard.writeText(text);
							button.innerText = 'Copied!';
							setTimeout(() => (button.innerText = 'Copy'), 2000);
						});
					}
				});
			}

			initGlobalScripts();
			document.addEventListener('astro:page-load', initGlobalScripts);
		</script>
	</body>
</html>

<style is:global>
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
